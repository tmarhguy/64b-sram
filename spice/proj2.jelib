Ngeneric:Invisible-Pin|pin@192||440|63|||||SIM_spice_card(D5G1;)S[* ============================================================================,* 16x4 SRAM FUNCTIONAL VALIDATION,* ============================================================================,* Test sequence:,* 1) Write 0x5 to address 0,* 2) Write 0xA to address 1,* 3) Read address 0 (expect 0x5),* 4) Read address 1 (expect 0xA),* 5) Write 0xF to address 2 (additional stress),* ============================================================================,.global gnd vdd,Vdd vdd 0 DC 1.0,* Clock: 500 MHz (2 ns period),Vclk CLK 0 PULSE(0 1.0 100p 10p 10p 990p 2n),* Address sequence:,* 0-2ns: addr=0,* 2-4ns: addr=1,* 4-6ns: addr=0 (read),* 6-8ns: addr=1 (read),* 8-10ns: addr=2,Va3 A_3 0 PWL(0 0  20n 0),Va2 A_2 0 PWL(0 0  8n 0  8.01n 1  20n 1),Va1 A_1 0 PWL(0 0  8n 0  8.01n 1  20n 1),Va0 A_0 0 PWL(0 0  2n 0  2.01n 1  4n 1  4.01n 0  6n 0  6.01n 1  8n 1  8.01n 0  20n 0),* Data sequence:,* 0-2ns: 0x5 (0101),* 2-8ns: 0xA (1010),* 8-10ns: 0xF (1111),Vd3 Din_3 0 PWL(0 0  2n 0  2.01n 1  8n 1  8.01n 1  20n 1),Vd2 Din_2 0 PWL(0 1  2n 1  2.01n 0  8n 0  8.01n 1  20n 1),Vd1 Din_1 0 PWL(0 0  2n 0  2.01n 1  8n 1  8.01n 1  20n 1),Vd0 Din_0 0 PWL(0 1  2n 1  2.01n 0  8n 0  8.01n 1  20n 1),* Write enable:,"* High during writes, low during read window",Vwe WE 0 PWL(0 1  3.6n 1  3.61n 0  8n 0  8.01n 1  20n 1),.control,tran 10p 12n,"echo \" \"","echo \"========================================================================\"","echo \"                    16x4 SRAM FUNCTIONAL VALIDATION\"","echo \"========================================================================\"","echo \"Write phase: 0-4 ns\"","echo \"Read phase : 4-8 ns\"","echo \"Extra write: 8-10 ns\"","echo \" \"",* Readback sampling points,meas tran D0_at_5ns find v(Dout_0) at=5n,meas tran D1_at_5ns find v(Dout_1) at=5n,meas tran D2_at_5ns find v(Dout_2) at=5n,meas tran D3_at_5ns find v(Dout_3) at=5n,meas tran D0_at_7ns find v(Dout_0) at=7n,meas tran D1_at_7ns find v(Dout_1) at=7n,meas tran D2_at_7ns find v(Dout_2) at=7n,meas tran D3_at_7ns find v(Dout_3) at=7n,* Timing metric: CLK-to-Dout (read of address 0),meas tran t_clk_to_dout trig v(CLK) val=0.5 rise=3 targ v(Dout_0) val=0.5 cross=1 td=4n,* Power metric: average supply current over full run,meas tran iavg_vdd avg i(Vdd) from=0n to=12n,let pavg_mw = -iavg_vdd * 1.0 * 1e3,* Convert sampled outputs to hexadecimal-equivalent values,let hex_5ns = D3_at_5ns*8 + D2_at_5ns*4 + D1_at_5ns*2 + D0_at_5ns,let hex_7ns = D3_at_7ns*8 + D2_at_7ns*4 + D1_at_7ns*2 + D0_at_7ns,"echo \"========================================================================\"","echo \"Readback @5 ns (expect 0x5 = 0101)\"","echo \"========================================================================\"",print D3_at_5ns D2_at_5ns D1_at_5ns D0_at_5ns,print hex_5ns,"echo \"========================================================================\"","echo \"Readback @7 ns (expect 0xA = 1010)\"","echo \"========================================================================\"",print D3_at_7ns D2_at_7ns D1_at_7ns D0_at_7ns,print hex_7ns,"echo \"========================================================================\"","echo \"Performance Metrics\"","echo \"========================================================================\"",print t_clk_to_dout,print iavg_vdd,print pavg_mw,let f_eq_ghz = 1e-9 / t_clk_to_dout,print f_eq_ghz,"echo \"========================================================================\"","echo \"Validation Status\"","echo \"========================================================================\"",if abs(hex_5ns - 5) < 0.5,"    echo \"Address 0 readback: PASS\"",else,"    echo \"Address 0 readback: FAIL\"",end,if abs(hex_7ns - 10) < 0.5,"    echo \"Address 1 readback: PASS\"",else,"    echo \"Address 1 readback: FAIL\"",end,if t_clk_to_dout > 0,"    echo \"Timing measurement: VALID\"",else,"    echo \"Timing measurement: INVALID\"",end,"echo \"========================================================================\"","echo \" \"",set hcopydevtype=svg,hardcopy waveforms/sram_full_validation.svg v(CLK)+12 v(WE)+10 v(A_1)+8 v(A_0)+6 v(Din_0)+4 v(Dout_0)+2 v(Dout_1) v(Dout_2)-2 v(Dout_3)-4 title 'SRAM Full Validation',plot v(CLK)+12 v(WE)+10 v(A_1)+8 v(A_0)+6 v(Din_0)+4 v(Dout_0)+2 v(Dout_1) v(Dout_2)-2 v(Dout_3)-4 title 'SRAM Write/Read Validation',.endc]
